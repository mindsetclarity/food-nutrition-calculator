---
import Layout from '../layouts/Layout.astro';
import NutritionLabel from '../components/nutrition-label/NutritionLabel.astro';
---

<Layout title="Recipe Nutrition Calculator">
  <main class="max-w-5xl mx-auto p-4 sm:p-6 space-y-8">
    <header class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Recipe Nutrition Calculator</h1>
      <p class="text-gray-600">Paste your recipe ingredients to see total and per-serving nutrition facts.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Left Column: Input -->
      <div class="space-y-6">
        <section class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h2 class="text-xl font-semibold mb-4">Recipe Details</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Recipe Name (Optional)</label>
              <input type="text" id="recipe-name" placeholder="e.g. Protein Oat Bowl" class="w-full p-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-blue-500"/>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Servings</label>
              <input type="number" id="recipe-servings" value="2" min="1" class="w-full p-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-blue-500"/>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ingredients</label>
              <p class="text-xs text-gray-500 mb-2">Enter one ingredient per line for best results.</p>
              <textarea id="recipe-ingredients" rows="8" placeholder="1 cup rolled oats&#10;1 banana&#10;2 tbsp peanut butter&#10;1 cup almond milk" class="w-full p-2 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <button id="btn-analyze" class="flex-1 py-3 sm:py-2 px-4 bg-blue-600 text-white font-medium rounded hover:bg-blue-700 transition text-base sm:text-sm">
                Analyze Recipe
              </button>
              <button id="btn-example" class="w-full sm:w-auto py-3 sm:py-2 px-4 bg-gray-100 text-gray-700 font-medium rounded hover:bg-gray-200 transition text-base sm:text-sm">
                Example
              </button>
            </div>

            <div id="loading-state" class="hidden text-blue-600 text-center text-sm">
              Analyzing ingredients...
            </div>
            <div id="error-state" class="hidden text-red-600 text-center text-sm p-2 bg-red-50 rounded"></div>
          </div>
        </section>

        <!-- Ingredient Review -->
        <section id="review-section" class="hidden bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h2 class="text-xl font-semibold mb-4">Review matched ingredients</h2>
          <div id="ingredients-list" class="space-y-3"></div>
          
          <div id="source-summary" class="mt-4 pt-4 border-t text-sm text-gray-500"></div>
          <div id="recipe-warnings" class="mt-2 space-y-2"></div>
        </section>
      </div>

      <!-- Right Column: Results -->
      <div class="space-y-6">
        <section id="results-section" class="hidden bg-white p-6 rounded-xl shadow-sm border border-gray-200 sticky top-6">
          <h2 class="text-2xl font-bold mb-6 border-b pb-2">Results</h2>
          
          <div class="mb-8">
            <h3 class="text-lg font-semibold text-gray-700 mb-3">Per Serving</h3>
            <div id="label-container" class="flex justify-center">
              <!-- Render via custom element to easily re-mount astro component logic via JS isn't native, so we'll just manipulate the DOM of the label component or fetch an HTML fragment. -->
              <!-- To keep it simple without heavy client state, we'll build the Nutrition Facts label directly in DOM here, or have a generic label structure that we update values for. -->
              <div class="border-2 border-black p-2 w-full max-w-sm bg-white font-sans text-black">
                <h2 class="text-3xl font-bold border-b-8 border-black pb-1 mb-1">Nutrition Facts</h2>
                <div class="flex justify-between items-end border-b-4 border-black pb-1 mb-1">
                  <div>
                    <div class="font-bold">Servings</div>
                    <div class="text-xs" id="lbl-servings-text">Based on 1 serving</div>
                  </div>
                </div>
                <div class="flex justify-between items-end border-b-4 border-black pb-1 mb-1">
                  <div>
                    <div class="font-bold text-sm">Amount per serving</div>
                    <div class="text-3xl font-extrabold">Calories</div>
                  </div>
                  <div class="text-4xl font-extrabold" id="lbl-calories">0</div>
                </div>
                <div class="border-b-4 border-black py-1 space-y-1">
                  <div class="flex justify-between"><div><span class="font-bold">Total Fat</span> <span id="lbl-fat">0g</span></div></div>
                  <div class="flex justify-between"><div><span class="font-bold">Total Carbohydrate</span> <span id="lbl-carbs">0g</span></div></div>
                  <div class="flex justify-between"><div><span class="font-bold">Protein</span> <span id="lbl-protein">0g</span></div></div>
                </div>
                <div class="text-xs text-gray-500 mt-2">
                  * For personal planning only. Not a commercial packaging label. Calculated by Nutrition Engine V2.
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-gray-700 mb-3 border-b pb-2">Total Recipe</h3>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div class="bg-gray-50 p-3 rounded">
                <div class="text-gray-500">Calories</div>
                <div class="font-bold text-lg" id="tot-calories">0</div>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <div class="text-gray-500">Protein</div>
                <div class="font-bold text-lg" id="tot-protein">0g</div>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <div class="text-gray-500">Carbs</div>
                <div class="font-bold text-lg" id="tot-carbs">0g</div>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <div class="text-gray-500">Fat</div>
                <div class="font-bold text-lg" id="tot-fat">0g</div>
              </div>
            </div>
          </div>

        </section>
      </div>

    </div>
  </main>

  <script>
    const els = {
      name: document.getElementById('recipe-name'),
      servings: document.getElementById('recipe-servings'),
      ingredients: document.getElementById('recipe-ingredients'),
      btnAnalyze: document.getElementById('btn-analyze'),
      btnExample: document.getElementById('btn-example'),
      loading: document.getElementById('loading-state'),
      error: document.getElementById('error-state'),
      reviewSection: document.getElementById('review-section'),
      resultsSection: document.getElementById('results-section'),
      ingList: document.getElementById('ingredients-list'),
      sourceSummary: document.getElementById('source-summary'),
      recipeWarnings: document.getElementById('recipe-warnings'),
      
      lblServings: document.getElementById('lbl-servings-text'),
      lblCal: document.getElementById('lbl-calories'),
      lblFat: document.getElementById('lbl-fat'),
      lblCarb: document.getElementById('lbl-carbs'),
      lblPro: document.getElementById('lbl-protein'),
      
      totCal: document.getElementById('tot-calories'),
      totFat: document.getElementById('tot-fat'),
      totCarb: document.getElementById('tot-carbs'),
      totPro: document.getElementById('tot-protein'),
    };

    els.btnExample.addEventListener('click', () => {
      els.name.value = "Protein Oat Bowl";
      els.servings.value = "2";
      els.ingredients.value = "1 cup rolled oats\n1 banana\n2 tbsp peanut butter\n1 cup almond milk\n1 tbsp chia seeds";
    });

    els.btnAnalyze.addEventListener('click', async () => {
      els.loading.classList.remove('hidden');
      els.error.classList.add('hidden');
      els.reviewSection.classList.add('hidden');
      els.resultsSection.classList.add('hidden');
      
      try {
        const text = els.ingredients.value.trim();
        if (!text) throw new Error("Please enter ingredients");

        const res = await fetch('/api/recipe/calculate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            recipeName: els.name.value.trim(),
            ingredientsText: text,
            servings: parseInt(els.servings.value) || 1
          })
        });

        const json = await res.json();
        if (json.error) throw new Error(json.error);
        
        renderResults(json);
      } catch (err) {
        els.error.textContent = err.message;
        els.error.classList.remove('hidden');
      } finally {
        els.loading.classList.add('hidden');
      }
    });

    function renderResults(res) {
      const { data, warnings, sourceSummary } = res;
      
      // Render ingredients
      els.ingList.innerHTML = data.ingredients.map(ing => `
        <div class="p-3 bg-gray-50 border rounded text-sm flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
          <div class="min-w-0 flex-1 break-words w-full">
            <div class="font-medium text-gray-900">${ing.originalText}</div>
            <div class="text-xs text-gray-600 mt-1">
              ${ing.calculatedItem ? `
                Matched: <strong>${ing.calculatedItem.displayName}</strong> (${Math.round(ing.calculatedItem.grams)}g)
                <span class="inline-block px-1 ml-1 bg-gray-200 rounded">${ing.calculatedItem.source.toUpperCase()}</span>
              ` : `
                <span class="text-red-500">Unresolved match</span>
              `}
            </div>
            ${ing.warnings.length > 0 ? `<div class="text-yellow-700 text-xs mt-1 border-l-2 border-yellow-400 pl-2 break-words">${ing.warnings.map(w=>w.message).join('<br>')}</div>` : ''}
          </div>
          <div class="text-left sm:text-right font-bold shrink-0">
            ${ing.calculatedItem ? Math.round(ing.calculatedItem.nutrients.calories || 0) + ' kcal' : ''}
          </div>
        </div>
      `).join('');

      // Summaries & Warnings
      els.sourceSummary.innerHTML = `<strong>Sources:</strong> ${sourceSummary.labels.join(', ')}`;
      els.recipeWarnings.innerHTML = warnings.map(w => `<div class="text-xs p-2 bg-yellow-100 text-yellow-800 rounded border border-yellow-200">⚠️ ${w.message}</div>`).join('');

      // Labels - Per Serving
      const per = data.perServingNutrition;
      els.lblServings.textContent = `Based on ${data.servings} serving(s)`;
      els.lblCal.textContent = Math.round(per.calories || 0);
      els.lblFat.textContent = Math.round(per.fat || 0) + 'g';
      els.lblCarb.textContent = Math.round(per.carbs || 0) + 'g';
      els.lblPro.textContent = Math.round(per.protein || 0) + 'g';

      // Totals
      const tot = data.totalNutrition;
      els.totCal.textContent = Math.round(tot.calories || 0);
      els.totFat.textContent = Math.round(tot.fat || 0) + 'g';
      els.totCarb.textContent = Math.round(tot.carbs || 0) + 'g';
      els.totPro.textContent = Math.round(tot.protein || 0) + 'g';

      els.reviewSection.classList.remove('hidden');
      els.resultsSection.classList.remove('hidden');
    }
  </script>
</Layout>
