---
import Layout from '../layouts/Layout.astro';
import SourceBadge from '../components/ui/SourceBadge.astro';
---

<Layout title="Food Nutrition Calculator">
  <main class="max-w-4xl mx-auto p-4 sm:p-6 space-y-8">
    <header class="text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Food Nutrition Calculator</h1>
      <p class="text-gray-600">Search and add foods to calculate complete nutrition totals.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column: Search & Added Foods -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Search Section -->
        <section class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h2 class="text-xl font-semibold mb-4">Add Food</h2>
          <div class="relative">
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search banana, oats, chicken breast..." 
              class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
            <div id="search-loading" class="hidden absolute right-3 top-3 text-gray-400">Loading...</div>
          </div>
          <div id="search-results" class="mt-4 space-y-2 max-h-96 overflow-y-auto"></div>
        </section>

        <!-- Selected Items Section -->
        <section class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h2 class="text-xl font-semibold mb-4">Selected Foods</h2>
          <div id="selected-items" class="space-y-4">
            <p class="text-gray-500 italic" id="empty-state">Add a food to see totals.</p>
          </div>
        </section>

      </div>

      <!-- Right Column: Totals -->
      <div class="lg:col-span-1">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 sticky top-6">
          <h2 class="text-xl font-semibold mb-4">Totals</h2>
          
          <div class="space-y-4">
            <div class="flex justify-between items-center pb-2 border-b">
              <span class="font-medium text-gray-700">Calories</span>
              <span id="total-calories" class="font-bold text-xl">0</span>
            </div>
            <div class="flex justify-between items-center pb-2 border-b">
              <span class="font-medium text-gray-700">Protein</span>
              <span id="total-protein" class="font-semibold text-lg">0g</span>
            </div>
            <div class="flex justify-between items-center pb-2 border-b">
              <span class="font-medium text-gray-700">Carbs</span>
              <span id="total-carbs" class="font-semibold text-lg">0g</span>
            </div>
            <div class="flex justify-between items-center pb-2 border-b">
              <span class="font-medium text-gray-700">Fat</span>
              <span id="total-fat" class="font-semibold text-lg">0g</span>
            </div>
            
            <div class="pt-4 space-y-2 text-sm text-gray-600">
              <div class="flex justify-between">
                <span>Fiber</span>
                <span id="total-fiber">0g</span>
              </div>
              <div class="flex justify-between">
                <span>Sugar</span>
                <span id="total-sugar">0g</span>
              </div>
              <div class="flex justify-between">
                <span>Sodium</span>
                <span id="total-sodium">0mg</span>
              </div>
            </div>
          </div>
          
          <div id="source-summary" class="mt-6 pt-4 border-t text-sm text-gray-500"></div>
          <div id="warnings-container" class="mt-4 space-y-2"></div>
        </div>
      </div>
    </div>
  </main>

  <script>
    let selectedFoods = [];
    let searchTimeout;

    const els = {
      searchInput: document.getElementById('search-input'),
      searchResults: document.getElementById('search-results'),
      searchLoading: document.getElementById('search-loading'),
      selectedItems: document.getElementById('selected-items'),
      emptyState: document.getElementById('empty-state'),
      totalCalories: document.getElementById('total-calories'),
      totalProtein: document.getElementById('total-protein'),
      totalCarbs: document.getElementById('total-carbs'),
      totalFat: document.getElementById('total-fat'),
      totalFiber: document.getElementById('total-fiber'),
      totalSugar: document.getElementById('total-sugar'),
      totalSodium: document.getElementById('total-sodium'),
      sourceSummary: document.getElementById('source-summary'),
      warningsContainer: document.getElementById('warnings-container'),
    };

    els.searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();
      if (!query) {
        els.searchResults.innerHTML = '';
        return;
      }
      els.searchLoading.classList.remove('hidden');
      searchTimeout = setTimeout(() => performSearch(query), 300);
    });

    async function performSearch(query) {
      try {
        const res = await fetch(`/api/foods/search?q=${encodeURIComponent(query)}`);
        const json = await res.json();
        renderSearchResults(json.data || [], json.fallbackUsed);
      } catch (err) {
        els.searchResults.innerHTML = '<p class="text-red-500 p-2">Search failed. Try again.</p>';
      } finally {
        els.searchLoading.classList.add('hidden');
      }
    }

    function renderSearchResults(results, fallbackUsed) {
      if (results.length === 0) {
        els.searchResults.innerHTML = '<p class="text-gray-500 p-2">No foods found. Try a simpler name like "banana" or "rice".</p>';
        return;
      }
      
      let html = '';
      if (fallbackUsed) {
        html += `<p class="text-sm text-yellow-600 mb-2">USDA search is unavailable right now. Showing local estimates where available.</p>`;
      }

      html += results.map(r => `
        <div class="flex items-center justify-between p-3 bg-gray-50 border rounded-lg hover:bg-gray-100 transition">
          <div>
            <div class="font-medium">${r.displayName}</div>
            <div class="text-xs text-gray-500 mt-1">
              ${r.calories ? r.calories + ' kcal' : 'N/A'} 
              <span class="inline-block px-2 py-0.5 ml-2 text-xs rounded bg-gray-200">${r.source.toUpperCase()}</span>
            </div>
          </div>
          <button onclick="addFood('${r.id}', '${r.source}')" class="px-3 py-1 bg-blue-600 text-white rounded shadow hover:bg-blue-700 text-sm">
            Add
          </button>
        </div>
      `).join('');
      
      els.searchResults.innerHTML = html;
    }

    window.addFood = async function(foodId, sourceHint) {
      els.searchInput.value = '';
      els.searchResults.innerHTML = '';
      
      // Default to 1 serving. This requires resolving details.
      try {
        // Fetch full detail for the food
        const res = await fetch(`/api/foods/details?id=${encodeURIComponent(foodId)}&source=${encodeURIComponent(sourceHint)}`);
        const json = await res.json();
        
        if (json.error) throw new Error(json.error);
        
        const food = json.data;
        const defaultServing = food.servingSizes?.find(s => s.isDefault) || food.servingSizes?.[0] || { id: "100g", unit: "g" };
        
        const id = crypto.randomUUID();
        selectedFoods.push({
          id,
          food,
          quantity: 1,
          unit: defaultServing.unit,
          servingId: defaultServing.id
        });
        
        recalculateAndRender();
      } catch (err) {
        alert(err.message || "Failed to add food");
      }
    };

    window.removeFood = function(id) {
      selectedFoods = selectedFoods.filter(f => f.id !== id);
      recalculateAndRender();
    };

    window.updateFoodQuantity = function(id, quantity, unit) {
      const food = selectedFoods.find(f => f.id === id);
      if (food) {
        food.quantity = parseFloat(quantity) || 1;
        food.unit = unit;
        recalculateAndRender();
      }
    };

    // Note: To remain true to Phase 9 rules: "UI should not calculate nutrition directly".
    // We send the array of simple selections to the engine, and it responds with the exact state.
    async function recalculateAndRender() {
      if (selectedFoods.length === 0) {
        renderEmptyState();
        return;
      }

      try {
        const res = await fetch('/api/calculator/totals', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: selectedFoods })
        });
        const json = await res.json();
        if (json.error) throw new Error(json.error);
        
        const state = json.data;
        renderSelectedItems(state.items);
        renderTotals(state);
      } catch (err) {
        console.error(err);
      }
    }

    function renderEmptyState() {
      els.selectedItems.innerHTML = '<p class="text-gray-500 italic" id="empty-state">Add a food to see totals.</p>';
      els.totalCalories.textContent = '0';
      els.totalProtein.textContent = '0g';
      els.totalCarbs.textContent = '0g';
      els.totalFat.textContent = '0g';
      els.totalFiber.textContent = '0g';
      els.totalSugar.textContent = '0g';
      els.totalSodium.textContent = '0mg';
      els.sourceSummary.innerHTML = '';
      els.warningsContainer.innerHTML = '';
    }

    function renderSelectedItems(items) {
      els.selectedItems.innerHTML = items.map(item => `
        <div class="flex items-start justify-between p-4 bg-gray-50 border rounded-lg">
          <div class="flex-1">
            <div class="font-medium text-lg">${item.displayName}</div>
            
            <div class="flex items-center gap-2 mt-2">
              <input type="number" step="0.1" min="0.1" value="${item.quantity}" 
                onchange="updateFoodQuantity('${item.id}', this.value, '${item.unit}', '${item.resolvedServing?.servingId || ''}')"
                class="w-20 p-1 border border-gray-300 rounded text-sm" />
              
              <select onchange="updateFoodUnit('${item.id}', this.value)" class="p-1 border border-gray-300 rounded text-sm max-w-[150px]">
                <option value="${item.unit}" selected>${item.resolvedServing?.servingLabel || item.unit}</option>
                <!-- Wait, normally we'd list other available units here. For simplicity in Phase 9, we just show the resolved one, or allow switching to grams. -->
                <option value="g">grams</option>
                <option value="oz">oz</option>
              </select>
            </div>

            <div class="text-xs text-gray-500 mt-2 flex items-center gap-2">
              <span>${Math.round(item.grams)}g</span>
              <span class="inline-block px-2 py-0.5 rounded bg-gray-200">${item.source.toUpperCase()}</span>
            </div>
            
            ${item.warnings.length > 0 ? `
              <div class="mt-2 text-xs text-yellow-700 bg-yellow-50 p-2 rounded">
                ${item.warnings.map(w => w.message).join(' | ')}
              </div>
            ` : ''}
          </div>
          
          <div class="text-right ml-4">
            <div class="font-bold">${Math.round(item.nutrients.calories || 0)} kcal</div>
            <div class="text-xs text-gray-500">${Math.round(item.nutrients.protein || 0)}g P</div>
            <button onclick="removeFood('${item.id}')" class="mt-2 text-xs text-red-600 hover:underline">Remove</button>
          </div>
        </div>
      `).join('');
    }

    function renderTotals(state) {
      els.totalCalories.textContent = Math.round(state.totals.calories || 0);
      els.totalProtein.textContent = Math.round(state.totals.protein || 0) + 'g';
      els.totalCarbs.textContent = Math.round(state.totals.carbs || 0) + 'g';
      els.totalFat.textContent = Math.round(state.totals.fat || 0) + 'g';
      els.totalFiber.textContent = Math.round(state.totals.fiber || 0) + 'g';
      els.totalSugar.textContent = Math.round(state.totals.sugar || 0) + 'g';
      els.totalSodium.textContent = Math.round(state.totals.sodium || 0) + 'mg';

      if (state.sourceSummary) {
        els.sourceSummary.innerHTML = `
          <strong>Sources used:</strong> ${state.sourceSummary.labels.join(', ')}
          ${state.sourceSummary.hasLocal && !state.sourceSummary.hasUsda ? '<br/><em>Note: Local estimates used due to USDA unavailability.</em>' : ''}
        `;
      } else {
        els.sourceSummary.innerHTML = '';
      }

      els.warningsContainer.innerHTML = state.warnings.map(w => `
        <div class="text-xs p-2 bg-yellow-100 text-yellow-800 rounded border border-yellow-200">
          ⚠️ ${w.message}
        </div>
      `).join('');
    }

    window.updateFoodQuantity = function(id, quantity, unit, servingId) {
      const food = selectedFoods.find(f => f.id === id);
      if (food) {
        food.quantity = parseFloat(quantity) || 1;
        // Keep unit/servingId identical to whatever it was before unless changed
        recalculateAndRender();
      }
    };

    window.updateFoodUnit = function(id, unit) {
      const food = selectedFoods.find(f => f.id === id);
      if (food) {
        food.unit = unit;
        food.servingId = null; // reset specific serving if they chose a generic one
        recalculateAndRender();
      }
    };
  </script>
</Layout>
