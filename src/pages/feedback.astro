---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Send Feedback - Food Nutrition Calculator">
  <main class="max-w-2xl mx-auto p-4 sm:p-6 space-y-8">
    <header class="text-center">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Send Feedback</h1>
      <p class="text-gray-600">Help us improve Food Nutrition Calculator. Report bugs, food data issues, or ideas for better tools.</p>
    </header>

    <section class="bg-white p-6 sm:p-8 rounded-xl shadow-sm border border-gray-200">
      <form id="feedback-form" class="space-y-6">
        <!-- Honeypot for simple spam protection -->
        <div class="hidden" aria-hidden="true">
          <label for="companyWebsite">Website</label>
          <input type="text" id="companyWebsite" name="companyWebsite" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name (Optional)</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              placeholder="Your name" 
              class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email (Recommended)</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              placeholder="your@email.com" 
              class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="feedbackType" class="block text-sm font-medium text-gray-700 mb-1">Feedback Type <span class="text-red-500" aria-label="required">*</span></label>
            <select 
              id="feedbackType" 
              name="feedbackType" 
              required
              class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            >
              <option value="" disabled selected>Select an option</option>
              <option value="General feedback">General feedback</option>
              <option value="Bug report">Bug report</option>
              <option value="Food data issue">Food data issue</option>
              <option value="Recipe calculator issue">Recipe calculator issue</option>
              <option value="Feature request">Feature request</option>
              <option value="Design/UI feedback">Design/UI feedback</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label for="pageTool" class="block text-sm font-medium text-gray-700 mb-1">Page or Tool (Optional)</label>
            <select 
              id="pageTool" 
              name="pageTool" 
              class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            >
              <option value="" selected>Select an option</option>
              <option value="Homepage">Homepage</option>
              <option value="Food Calculator">Food Calculator</option>
              <option value="Recipe Calculator">Recipe Calculator</option>
              <option value="Meal Calculator">Meal Calculator</option>
              <option value="Compare Foods">Compare Foods</option>
              <option value="Foods Directory">Foods Directory</option>
              <option value="Learn Hub">Learn Hub</option>
              <option value="Mobile Menu">Mobile Menu</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        <div>
          <fieldset>
            <legend class="block text-sm font-medium text-gray-700 mb-2">Rating (Optional)</legend>
            <div class="flex items-center gap-2 sm:gap-4 flex-wrap">
              {[1, 2, 3, 4, 5].map((num) => (
                <label class="flex flex-col items-center cursor-pointer">
                  <input type="radio" name="rating" value={num} class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500" />
                  <span class="text-xs text-gray-500 mt-1">{num}</span>
                </label>
              ))}
            </div>
            <div class="flex justify-between text-xs text-gray-400 mt-1 max-w-[140px] sm:max-w-[200px]">
              <span>1 = Poor</span>
              <span>5 = Excellent</span>
            </div>
          </fieldset>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500" aria-label="required">*</span></label>
          <textarea 
            id="message" 
            name="message" 
            required 
            minlength="10" 
            maxlength="3000" 
            rows="5"
            placeholder="Tell us what happened, what you expected, or what you want improved."
            class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"
          ></textarea>
        </div>

        <div class="flex items-start">
          <div class="flex items-center h-5">
            <input 
              id="contactPermission" 
              name="contactPermission" 
              type="checkbox" 
              class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
            />
          </div>
          <div class="ml-3 text-sm">
            <label for="contactPermission" class="font-medium text-gray-700 cursor-pointer">You may contact me about this feedback.</label>
          </div>
        </div>

        <!-- Hidden metadata -->
        <input type="hidden" name="currentUrl" id="currentUrl" />
        <input type="hidden" name="userAgent" id="userAgent" />

        <div class="pt-2">
          <p class="text-xs text-gray-500 mb-4 text-center">
            Please do not include passwords, private medical details, or payment information.
          </p>
          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-blue-600 text-white font-medium py-3 px-4 rounded-lg shadow hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Feedback
          </button>
        </div>

        <div id="form-message" class="hidden mt-4 p-4 rounded-lg text-sm text-center" role="alert"></div>
      </form>
    </section>
  </main>

  <script>
    const form = document.getElementById('feedback-form');
    const submitBtn = document.getElementById('submit-btn');
    const formMessage = document.getElementById('form-message');

    // Populate hidden metadata
    document.getElementById('currentUrl').value = window.location.href;
    document.getElementById('userAgent').value = navigator.userAgent;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      // Basic validation
      if (!data.feedbackType || !data.message || data.message.length < 10) {
        showMessage('Please fill in all required fields properly.', 'error');
        return;
      }

      // Convert rating to number if exists
      if (data.rating) {
        data.rating = parseInt(data.rating, 10);
      }
      
      // Convert checkbox to boolean
      data.contactPermission = !!data.contactPermission;

      // Loading state
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      formMessage.classList.add('hidden');

      try {
        const res = await fetch('/api/feedback', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok) {
          showMessage('Thank you — your feedback has been sent.', 'success');
          form.reset();
        } else {
          showMessage(result.error || 'We couldn’t send your feedback right now. Please try again.', 'error');
        }
      } catch (err) {
        showMessage('We couldn’t send your feedback right now. Please try again.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Feedback';
      }
    });

    function showMessage(text, type) {
      formMessage.textContent = text;
      formMessage.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'bg-green-50', 'text-green-700', 'bg-yellow-50', 'text-yellow-700');
      
      if (type === 'success') {
        formMessage.classList.add('bg-green-50', 'text-green-700');
      } else if (type === 'error') {
        if (text.includes('configured')) {
          formMessage.classList.add('bg-yellow-50', 'text-yellow-700');
        } else {
          formMessage.classList.add('bg-red-50', 'text-red-700');
        }
      }
    }
  </script>
</Layout>
