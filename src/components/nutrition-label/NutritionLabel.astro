---
import type { NutritionTotals } from '../../lib/nutrition-engine';

export interface Props {
  totals?: NutritionTotals;
  servings?: number;
}

const { totals, servings = 1 } = Astro.props;

function formatNum(num?: number) {
  if (typeof num !== 'number') return '0';
  return Math.round(num).toString();
}

function formatDec(num?: number) {
  if (typeof num !== 'number') return '0g';
  return (Math.round(num * 10) / 10).toString() + 'g';
}

function formatMg(num?: number) {
  if (typeof num !== 'number') return '0mg';
  return Math.round(num).toString() + 'mg';
}
---

{totals ? (
  <div class="border-2 border-black p-2 w-full max-w-sm bg-white font-sans text-black">
    <h2 class="text-3xl font-bold border-b-8 border-black pb-1 mb-1">Nutrition Facts</h2>
    <div class="flex justify-between items-end border-b-4 border-black pb-1 mb-1">
      <div>
        <div class="font-bold">Servings</div>
        <div class="text-xs">Based on {servings} serving(s)</div>
      </div>
    </div>
    <div class="flex justify-between items-end border-b-4 border-black pb-1 mb-1">
      <div>
        <div class="font-bold text-sm">Amount per serving</div>
        <div class="text-3xl font-extrabold">Calories</div>
      </div>
      <div class="text-4xl font-extrabold">{formatNum(totals.calories)}</div>
    </div>
    
    <div class="text-right text-xs font-bold border-b border-black pb-1 mb-1">% Daily Value*</div>
    
    <div class="border-b border-black py-1 flex justify-between">
      <div><span class="font-bold">Total Fat</span> {formatDec(totals.fat)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between pl-4">
      <div>Saturated Fat {formatDec(totals.saturatedFat)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between">
      <div><span class="font-bold">Cholesterol</span> {formatMg(totals.cholesterol)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between">
      <div><span class="font-bold">Sodium</span> {formatMg(totals.sodium)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between">
      <div><span class="font-bold">Total Carbohydrate</span> {formatDec(totals.carbs)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between pl-4">
      <div>Dietary Fiber {formatDec(totals.fiber)}</div>
    </div>
    <div class="border-b border-black py-1 flex justify-between pl-4">
      <div>Total Sugars {formatDec(totals.sugar)}</div>
    </div>
    <div class="border-b-4 border-black py-1 flex justify-between">
      <div><span class="font-bold">Protein</span> {formatDec(totals.protein)}</div>
    </div>
    
    <div class="border-b border-gray-300 py-1 flex justify-between">
      <div>Vitamin D</div>
      <div>-</div>
    </div>
    <div class="border-b border-gray-300 py-1 flex justify-between">
      <div>Calcium {formatMg(totals.calcium)}</div>
    </div>
    <div class="border-b border-gray-300 py-1 flex justify-between">
      <div>Iron {formatMg(totals.iron)}</div>
    </div>
    <div class="py-1 flex justify-between">
      <div>Potassium {formatMg(totals.potassium)}</div>
    </div>
    <div class="text-xs text-gray-500 mt-2">
      * For personal planning only. Not a commercial packaging label. Calculated by Nutrition Engine V2.
    </div>
  </div>
) : (
  <div class="text-gray-500 italic">No nutrition data available.</div>
)}
