---
export interface Props {
  source: string;
  label?: string;
  size?: 'sm' | 'md';
}

const { source, label, size = 'sm' } = Astro.props;

let colorClass = "bg-gray-100 text-gray-800 border-gray-200";
if (source === 'usda') {
  colorClass = "bg-green-100 text-green-800 border-green-200";
} else if (source === 'local' || source === 'curated') {
  colorClass = "bg-blue-100 text-blue-800 border-blue-200";
} else if (source === 'llm_parse' || source === 'estimated') {
  colorClass = "bg-yellow-100 text-yellow-800 border-yellow-200";
}

const sizeClass = size === 'sm' ? "text-xs px-2 py-0.5" : "text-sm px-3 py-1";
const displayLabel = label || source.toUpperCase();
---

<span class={`inline-block font-medium rounded border ${colorClass} ${sizeClass}`} title={`Source: ${displayLabel}`}>
  {displayLabel}
</span>
